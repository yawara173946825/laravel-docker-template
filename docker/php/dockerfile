FROM php:8.3-fpm

ARG env_name

# set timezone
RUN ln -sf /usr/share/zoneinfo/Asia/Tokyo /etc/localtime

# php-fpm設定ファイルのコピー
COPY ./phpfpm/conf.d/www.conf /usr/local/etc/php-fpm.d/www.conf
RUN chmod 644 /usr/local/etc/php-fpm.d/www.conf

# php.iniのコピー
COPY php.ini /usr/local/etc/php/php.ini
RUN chmod 644 /usr/local/etc/php/php.ini
RUN rm -f /usr/local/etc/php/php.ini-production /usr/local/etc/php/php.ini-development

# 必須パッケージのインストール
RUN apt-get update && apt-get install -y \
    git curl libpng-dev libonig-dev libxml2-dev zip unzip \
    && docker-php-ext-install pdo_mysql mbstring exif pcntl bcmath gd

# コンテンツのコピー
ADD --chown=www-data:www-data ./contents /var/www/html/

# TODOプロジェクト名を変える
WORKDIR /var/www/html/project

# Composerのバイナリを公式イメージからPHPにコピー
COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

# パッケージのインストールによって出る質問事項をスキップするために環境変数を設定
ENV COMPOSER_ALLOW_SUPERUSER 1
ENV COMPOSER_NO_INTERACTION 1

WORKDIR /var/www
